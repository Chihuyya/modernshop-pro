    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();\r",
                  "if (jsonData.status === 'success' && jsonData.token) {\r",
                  "    pm.collectionVariables.set('admin_token', jsonData.token);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"admin\",\r\n  \"password\": \"admin123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost/db_toko_online/modernshop-pro/public/api/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "path": [
                "db_toko_online",
                "modernshop-pro",
                "public",
                "api",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
